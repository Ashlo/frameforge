{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm --prefix .. run dev -- -p 1420",
    "beforeBuildCommand": "npm --prefix .. run build",
    "devPath": "http://localhost:1420",
    "distDir": "../.next"
  },
  "package": {
    "productName": "Frameforge Desktop",
    "version": "0.1.0"
  },
  "tauri": {
    "macOSPrivateApi": true,
    "allowlist": {
      "all": false,
      "window": {
        "all": true
      }
    },
    "bundle": {
      "active": false,
      "identifier": "com.frameforge.desktop",
      "targets": "all",
      "macOS": {
        "minimumSystemVersion": "12.0"
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Frameforge Desktop",
        "width": 1680,
        "height": 980,
        "minWidth": 1240,
        "minHeight": 760,
        "resizable": true
      }
    ]
  }
}
