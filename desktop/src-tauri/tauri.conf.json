{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm --prefix .. run dev",
    "beforeBuildCommand": "npm --prefix .. run build",
    "devPath": "http://127.0.0.1:1420",
    "distDir": "../../dist"
  },
  "package": {
    "productName": "Frameforge Demo Recorder",
    "version": "0.1.0"
  },
  "tauri": {
    "macOSPrivateApi": true,
    "allowlist": {
      "all": false,
      "window": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.frameforge.desktop",
      "targets": ["app"],
      "macOS": {
        "minimumSystemVersion": "12.0"
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Frameforge Demo Recorder",
        "width": 1560,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ]
  }
}
